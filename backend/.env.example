# Port the backend server listens on
PORT=5000

# Comma-separated list of frontend origins allowed to call this API
CORS_ORIGIN=http://localhost:5173

# SMTP settings for sending contact-form emails.
# For Gmail: use smtp.gmail.com, port 587, and a 16-character "App Password"
# (not your normal password) — generate one at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password

# Where contact-form messages get delivered (defaults to SMTP_USER if unset)
CONTACT_TO_EMAIL=your-email@gmail.com
